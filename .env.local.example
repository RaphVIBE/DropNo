# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ygzyzvjxregoqbzmcmyq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_CCtEsFQO-3MxGwmIP-jjlg_dsJvjOKn
SUPABASE_SERVICE_ROLE_KEY=                # Dashboard → Settings → API. NE PAS commit.

# Stripe — dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                    # via Stripe CLI : stripe listen --forward-to localhost:3000/api/stripe/webhook

# Resend (emails transactionnels)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dropno.eu

# Secret partage entre l'edge function close-drop et /api/notifications/*
# (declenchement des emails de resultat). A definir aussi cote Supabase
# (secret edge function NOTIFY_SECRET) avec la meme valeur.
NOTIFY_SECRET=

# PostHog (analytics) — optionnel en dev
# Tracking vitrine (cote navigateur) : cle projet publique.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Cadrans /admin (cote serveur) : PostHog → Settings → Project → Project ID,
# et Personal API key (scope query:read). NE PAS commit la cle.
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://eu.posthog.com

# Crisp (chat support) — optionnel en dev
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Environnement
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Barriere "site en construction" (acces prive avant le lancement public)
# SITE_LOCKED=true  -> le public voit /bientot sur toutes les routes (noindex).
#                      Les /api/* et assets restent accessibles.
# Acces complet pour toi et tes testeurs : visiter une fois
#   https://<domaine>/?preview=<PREVIEW_TOKEN>
# -> pose un cookie 30 jours qui debloque tout le site dans ce navigateur.
# Re-verrouiller un testeur : https://<domaine>/?preview=off
# PREVIEW_TOKEN : secret long et aleatoire (ex: openssl rand -hex 24).
# Laisser SITE_LOCKED vide (ou != true) ouvre le site normalement.
SITE_LOCKED=
PREVIEW_TOKEN=

# Demos prospects : un drop fictif par maison, montre en call via une URL gated.
#   https://<domaine>/demo/<slug>?key=<DEMO_KEY>
# -> page autonome (sans navigation) laissee passer par la barriere SITE_LOCKED,
#    donc jamais derriere « bientot ». Les drops demo ne sont jamais listes ni
#    clotures. La page verifie la cle elle-meme.
# DEMO_KEY : secret long et aleatoire (ex: openssl rand -hex 16). A poser aussi
# cote Netlify (env prod) pour des demos sur le site live.
DEMO_KEY=
